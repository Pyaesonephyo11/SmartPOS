<com.google.android.material.appbar.MaterialToolbar
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/toolbarPos"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="56dp"
    android:background="@android:color/white"
    android:padding="12dp">

    <LinearLayout

        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Title -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTitle"
                android:text="Smart POS"
                android:textSize="22sp"
                android:fontFamily="@font/interbold"
                android:textColor="#059669"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtSubTitle"
                android:text="Shop Management System"
                android:textSize="12sp"
                android:textColor="#777777"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/product"
            />

        <ImageView
            android:id="@+id/btnSaleHistory"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/salehistory"
            />

        <!-- Settings -->
        <ImageView
            android:id="@+id/bc"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/baseline_settings_24"
            />

        <!-- Cart -->
        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp">

            <ImageView
                android:id="@+id/btnCart"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/baseline_shopping_cart_24"
                />

            <TextView
                android:id="@+id/txtCartCount"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="top|end"
                android:background="@drawable/outline_circle_24"
                android:text="0"
                android:textSize="10sp"
                android:textColor="#A90404"
                android:gravity="center"
                android:visibility="gone"/>
        </FrameLayout>

    </LinearLayout>
</com.google.android.material.appbar.MaterialToolbar>