<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
   android:background="@drawable/bg_white_sale"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_marginBottom="0.5dp"
    android:layout_height="wrap_content">

    <LinearLayout
        android:padding="5dp"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Product Name -->
        <TextView
            android:layout_marginRight="5dp"
            android:id="@+id/tvManageName"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:text="Product"
            android:textSize="15sp"
            android:textColor="#282828"
            android:fontFamily="@font/intersemibold"
            android:layout_height="wrap_content"/>

        <!-- Category -->
        <TextView
            android:layout_marginRight="5dp"
            android:id="@+id/tvManageCategory"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="Category"
            android:gravity="center"
            android:textColor="#373636"
            android:background="@drawable/bgcategorymanage"
            android:layout_height="wrap_content"/>

        <!-- Price -->
        <TextView
            android:layout_marginRight="5dp"
            android:id="@+id/tvManagePrice"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="1000"
            android:fontFamily="@font/intersemibold"
            android:textColor="@color/light_green"
            android:layout_height="wrap_content"/>
        <LinearLayout
            android:id="@+id/barlayout"
            android:layout_marginRight="5dp"
            android:background="@drawable/bg_rev"
            android:layout_width="70dp"
            android:layout_height="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/imageprofit"
                android:layout_width="wrap_content"
                android:layout_height="23dp"
                android:contentDescription="percent"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:gravity="center"
                android:id="@+id/tvManageRevenue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10%"
                android:textColor="#373636"/>

        </LinearLayout>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="23dp"
            android:layout_marginRight="2dp"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnManageEdit"
                android:layout_width="23dp"
                android:layout_height="23dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/edit" />

            <ImageButton
                android:id="@+id/btnManageDelete"
                android:layout_width="23dp"
                android:layout_height="23dp"
                android:background="@drawable/delete" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
