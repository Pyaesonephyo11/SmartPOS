<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="vertical">

        <!-- IMPORTANT: NestedScrollView child MUST be ONE layout -->>

<LinearLayout

    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F1F1"
    android:padding="16dp">



    <com.google.android.material.button.MaterialButton
        android:id="@+id/back"
        android:layout_marginTop="20dp"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="Back to Shop (အရောင်းသို့)"
        app:backgroundTint="@color/appcolor"
        android:fontFamily="@font/intersemibold"
        android:textColor="@android:color/white"
        app:rippleColor="#80FFFFFF"
        app:cornerRadius="10dp" />
    <LinearLayout
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddNewCategory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Add New Category"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:textAllCaps="false"
            android:textSize="13sp"
           android:fontFamily="@font/intersemibold"
            android:backgroundTint="#059669"
            android:textColor="@android:color/white"
            app:cornerRadius="10dp"
            app:elevation="8dp"
            app:rippleColor="#80FFFFFF"
            app:pressedTranslationZ="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddNewProduct"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Add New Product"
            android:layout_weight="1"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:rippleColor="#80FFFFFF"
            android:fontFamily="@font/intersemibold"
            android:backgroundTint="#059669"
            android:textColor="@android:color/white"
            app:cornerRadius="10dp"
            app:elevation="8dp"
            app:pressedTranslationZ="12dp"/>

    </LinearLayout>


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvcategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="24dp"
        android:visibility="gone"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        android:backgroundTint="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Category"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"/>

            <!-- Input + Add -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Category name"
                    app:boxStrokeColor="@color/light_green"
                    app:hintTextColor="@color/light_green"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCategory"
                        android:textColor="@color/black"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAdd"
                    android:layout_width="80dp"
                    android:layout_height="48dp"
                    android:text="Add"
                    android:layout_marginStart="8dp"
                    app:backgroundTint="@color/light_green"
                    android:textColor="@android:color/white"
                    app:cornerRadius="12dp"/>
            </LinearLayout>

            <!-- Category Recycler -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ================= Add New Product ================= -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardviewnewproduct"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"
        android:visibility="gone"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        android:backgroundTint="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Product Details"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"/>

            <!-- Product Image -->
            <ImageView
                android:id="@+id/imgProduct"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginTop="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_launcher_foreground"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_white_round"
                android:padding="8dp"/>

            <!-- Product Name -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="Product Name"
                app:boxStrokeColor="@color/light_green"
                app:hintTextColor="@color/light_green"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etProductName"
                    android:textColor="@color/black"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Selling Price -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Selling Price"
                app:boxStrokeColor="@color/light_green"
                app:hintTextColor="@color/light_green"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etProductPrice"
                    android:textColor="@color/black"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Cost Price -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Cost Price"
                app:boxStrokeColor="@color/light_green"
                app:hintTextColor="@color/light_green"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCostPrice"
                    android:textColor="@color/black"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Stock -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Stock"
                app:boxStrokeColor="@color/light_green"
                app:hintTextColor="@color/light_green"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etStock"
                    android:textColor="@color/black"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Category Spinner -->
            <Spinner
                android:id="@+id/spCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_spinner_material"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"/>

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelProduct"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Cancel"
                    android:textColor="@android:color/white"
                    android:layout_marginEnd="12dp"
                    app:backgroundTint="#9CA3AF"
                    app:cornerRadius="14dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveProduct"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Save Product"
                    android:textColor="@android:color/white"
                    app:backgroundTint="@color/light_green"
                    app:cornerRadius="14dp"/>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:id="@+id/lowstockcard"
        android:visibility="gone"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#FFF1F1"
        android:layout_marginTop="10dp"
        app:cardCornerRadius="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:src="@drawable/alert"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    app:tint="#FF4D4D" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LOW STOCK ALERT"
                    android:textStyle="bold"
                    android:textColor="#FF4D4D"
                    android:layout_marginStart="8dp"
                    android:textSize="16sp"/>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Items requiring immediate attention"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginBottom="12dp"/>

            <!-- Recycler -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLowStock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>
    <!-- Search Box Container -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/appcolor">

        <!-- Horizontal layout inside search box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <!-- Search Icon -->
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/baseline_search_24"
                app:tint="#D1CFCF" />

            <!-- Search Input -->
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"

                android:hint="Search product..."
                android:textSize="15sp"

                android:textColor="@android:color/white"
                android:textColorHint="#B3FFFFFF"

                android:background="@null"

                android:inputType="text"
                android:imeOptions="actionSearch"
                android:maxLines="1"
                android:singleLine="true"
                android:ellipsize="end"

                android:paddingVertical="8dp"

                android:fontFamily="@font/interregular"

                android:importantForAutofill="no"
                android:textCursorDrawable="@null"/>



        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="5dp"
        android:backgroundTint="#DEDCDC"
        app:cardCornerRadius="10dp"
        app:cardElevation="5dp">
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:fillViewport="true">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_margin="10dp"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Product Name -->
            <TextView
                android:layout_marginLeft="5dp"
                android:textColor="#373636"
                android:layout_width="0dp"
                android:layout_weight="2"
                android:fontFamily="@font/intersemibold"
                android:text="Product"
                android:layout_height="wrap_content"/>

            <!-- Category -->
            <TextView
                android:fontFamily="@font/intersemibold"
                android:textColor="#373636"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Category"
                android:layout_height="wrap_content"/>

            <!-- Price -->
            <TextView
                android:layout_marginRight="20dp"
                android:textColor="#373636"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Selling Price"
                android:fontFamily="@font/intersemibold"
                android:layout_height="wrap_content"/>
            <!-- Profit -->
            <TextView
                android:fontFamily="@font/intersemibold"
                android:textColor="#373636"
                android:layout_width="wrap_content"
                android:text="Profit"
                android:layout_marginRight="23dp"
                android:layout_height="wrap_content"/>
            <!-- Actions -->
            <TextView
                android:fontFamily="@font/intersemibold"
                android:textColor="#373636"
                android:layout_width="wrap_content"
                android:text="Actions"
                android:layout_marginRight="2dp"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginVertical="3dp"/>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProductManage"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <include
                android:id="@+id/layoutEmpty"
                layout="@layout/layout_empty_search"/>
        </FrameLayout>


    </LinearLayout>
        </HorizontalScrollView>
    </androidx.cardview.widget.CardView>

</LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
