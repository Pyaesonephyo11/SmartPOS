<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color -->
    <solid android:color="#F4F2F2" />

    <!-- Corner radius -->
    <corners android:radius="12dp" />

    <!-- Optional border -->
    <stroke
        android:width="1dp"
        android:color="#F4F2F2" />

    <!-- Optional padding -->
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp" />
</shape>
