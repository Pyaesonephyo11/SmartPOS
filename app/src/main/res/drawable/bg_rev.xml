<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Soft gradient -->
    <gradient
        android:startColor="#FCF0FAF2"
        android:endColor="#FAEBF8EC"
        android:angle="45" />

    <!-- Rounded corners -->
    <corners android:radius="5dp" />

    <!-- Soft border -->
    <stroke
        android:width="1dp"
        android:color="#B9EBBC" />

    <!-- Inner padding -->
    <padding
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp" />
</shape>
